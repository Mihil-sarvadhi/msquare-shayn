{
  "name": "shayn-mis-backend",
  "version": "1.0.0",
  "description": "SHAYN MIS Backend — Node.js + Express + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "backfill:shopify": "ts-node src/backfill/shopifyBackfill.ts",
    "backfill:meta": "ts-node src/backfill/metaBackfill.ts",
    "backfill:ithink": "ts-node src/backfill/ithinkBackfill.ts",
    "backfill:judgeme": "ts-node src/backfill/judgeMeBackfill.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
