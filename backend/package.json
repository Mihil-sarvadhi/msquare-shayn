{
  "name": "shayn-mis-backend",
  "version": "1.0.0",
  "description": "SHAYN MIS Backend — Node.js + Express + Sequelize + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts --max-warnings 0",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "backfill:shopify": "tsx src/modules/shopify/shopify.backfill.ts",
    "backfill:shopify:refunds": "tsx src/scripts/backfill-refunds.ts refunds",
    "backfill:shopify:returns": "tsx src/scripts/backfill-refunds.ts returns",
    "probe:returns-split": "tsx src/scripts/probe-returns-split.ts",
    "backfill:shopify:transactions": "tsx src/scripts/backfill-refunds.ts transactions",
    "backfill:shopify:locations": "tsx src/scripts/backfill-refunds.ts locations",
    "backfill:shopify:analytics": "tsx src/scripts/backfill-analytics.ts",
    "backfill:meta": "tsx src/modules/meta/meta.backfill.ts",
    "backfill:ithink": "tsx src/modules/ithink/ithink.backfill.ts",
    "backfill:judgeme": "tsx src/modules/judgeme/judgeme.backfill.ts",
    "backfill:ga4": "tsx src/modules/ga4/ga4.backfill.ts",
    "backfill:unicommerce": "tsx src/modules/unicommerce/unicommerce.backfill.ts",
    "backfill:unicommerce:fixup": "tsx src/modules/unicommerce/unicommerce.fixup.ts",
    "backfill:unicommerce:inventory": "tsx src/modules/unicommerce/unicommerce.inventory.ts",
    "ga4:token": "node scripts/getGA4Token.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "express-rate-limit": "^7.4.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "winston": "^3.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/sequelize": "^4.28.20",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.4.2",
    "sequelize-cli": "^6.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
